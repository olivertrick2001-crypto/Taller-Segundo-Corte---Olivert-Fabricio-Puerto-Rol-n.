#include <iostream>
#include <vector>
#include <string>
class Persona {
private:
    std::string nombre;
    std::string apellido;
    int edad;
    std::string documento;

public:
    Persona(std::string nombre, std::string apellido, int edad, std::string documento)
        : nombre(nombre), apellido(apellido), edad(edad), documento(documento) {}

    virtual ~Persona() {}

    std::string getNombre() const { return nombre; }
    void setNombre(std::string nombre) { this->nombre = nombre; }

    std::string getApellido() const { return apellido; }
    void setApellido(std::string apellido) { this->apellido = apellido; }

    int getEdad() const { return edad; }
    void setEdad(int edad) { this->edad = edad; }

    std::string getDocumento() const { return documento; }
    void setDocumento(std::string documento) { this->documento = documento; }

    virtual void mostrarInformacion() const = 0;
};


